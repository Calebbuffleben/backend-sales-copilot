// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Multi-tenant core
//
// Identity model (non-negotiable):
//  - `User` is a GLOBAL identity. Email is unique across the platform.
//  - `Tenant` is a company/workspace.
//  - `Membership` links a User to a Tenant with a role. A user can belong
//    to many tenants and a tenant can have many users.
//  - `Subscription` is the billing record per tenant (plan + seat limit).
//  - `Invitation` is a pending link (tokenized) that becomes a Membership
//    when the invitee accepts.
//
// The JWT access token carries `sub` (userId), `tid` (tenantId) and `mid`
// (membershipId). The `mid` is the authoritative permission anchor — the
// backend rechecks it on every protected request.
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model Tenant {
  id        String       @id @default(uuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships    Membership[]
  invitations    Invitation[]
  subscription   Subscription?
  sessions       Session[]
  feedbackEvents FeedbackEvent[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  name         String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  sentInvites   Invitation[]   @relation("InvitationInvitedBy")
}

model Membership {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      MembershipRole @default(MEMBER)
  // Null when OWNER created the tenant; otherwise the membership that invited them.
  invitedBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Invitation {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  role        MembershipRole @default(MEMBER)
  // sha256(tokenPlaintext) — plaintext is returned to the admin ONCE.
  tokenHash   String         @unique
  status      InviteStatus   @default(PENDING)
  invitedById String
  invitedBy   User           @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([expiresAt])
}

model Subscription {
  id        String             @id @default(uuid())
  tenantId  String             @unique
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan      Plan               @default(FREE)
  maxUsers  Int                @default(3)
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([tenantId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Membership that minted this token. Used to short-circuit revoke when a
  // membership is removed (admin removes a user) and as an extra sanity
  // anchor during refresh (we re-verify the membership still exists).
  membershipId String?
  tokenHash    String    @unique
  familyId     String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdByIp  String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  @@index([tenantId, userId])
  @@index([familyId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  target    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}

// ---------------------------------------------------------------------------
// Meeting / feedback domain (tenant-scoped)
// ---------------------------------------------------------------------------

enum SessionStatus {
  ACTIVE
  ENDED
}

model Session {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetingId String
  roomSid   String?       @unique
  roomName  String
  status    SessionStatus @default(ACTIVE)
  startedAt DateTime      @default(now())
  endedAt   DateTime?

  @@unique([tenantId, meetingId])
  @@index([roomName])
  @@index([tenantId])
}

enum FeedbackSeverity {
  info
  warning
  critical
}

enum FeedbackType {
  volume_baixo
  volume_alto
  silencio_prolongado
  tendencia_emocional_negativa
  engajamento_baixo
  overlap_fala
  monologo_prolongado
  frustracao_crescente
  entusiasmo_alto
  monotonia_prosodica
  energia_grupo_baixa
  interrupcoes_frequentes
  polarizacao_emocional
  efeito_pos_interrupcao
  ritmo_acelerado
  ritmo_pausado
  // A2E2 (emoções/estados primários)
  hostilidade
  tedio
  confusao
  serenidade
  conexao
  tristeza
  estado_mental
  // Feedbacks de vendas (semântica)
  sales_price_window_open
  sales_decision_signal
  sales_ready_to_close
  sales_objection_escalating
  sales_conversation_stalling
  sales_category_transition
  sales_client_indecision
  sales_solution_understood
  conversation_dominance
  llm_insight
}

model FeedbackEvent {
  id            String           @id @default(uuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetingId     String
  participantId String
  type          FeedbackType
  severity      FeedbackSeverity
  ts            DateTime
  windowStart   DateTime
  windowEnd     DateTime
  message       String
  metadata      Json
  createdAt     DateTime         @default(now())
  expiresAt     DateTime?

  @@index([tenantId, meetingId, ts])
  @@index([expiresAt])
}
