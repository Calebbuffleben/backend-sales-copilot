// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Multi-tenant core
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id        String       @id @default(uuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users           User[]
  sessions        Session[]
  feedbackEvents  FeedbackEvent[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  SERVICE
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String?
  name         String?
  role         UserRole  @default(MEMBER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  familyId     String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdByIp  String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  @@index([tenantId, userId])
  @@index([familyId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  target    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}

// ---------------------------------------------------------------------------
// Meeting / feedback domain (tenant-scoped)
// ---------------------------------------------------------------------------

enum SessionStatus {
  ACTIVE
  ENDED
}

model Session {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetingId String
  roomSid   String?       @unique
  roomName  String
  status    SessionStatus @default(ACTIVE)
  startedAt DateTime      @default(now())
  endedAt   DateTime?

  @@unique([tenantId, meetingId])
  @@index([roomName])
  @@index([tenantId])
}

enum FeedbackSeverity {
  info
  warning
  critical
}

enum FeedbackType {
  volume_baixo
  volume_alto
  silencio_prolongado
  tendencia_emocional_negativa
  engajamento_baixo
  overlap_fala
  monologo_prolongado
  frustracao_crescente
  entusiasmo_alto
  monotonia_prosodica
  energia_grupo_baixa
  interrupcoes_frequentes
  polarizacao_emocional
  efeito_pos_interrupcao
  ritmo_acelerado
  ritmo_pausado
  // A2E2 (emoções/estados primários)
  hostilidade
  tedio
  confusao
  serenidade
  conexao
  tristeza
  estado_mental
  // Feedbacks de vendas (semântica)
  sales_price_window_open
  sales_decision_signal
  sales_ready_to_close
  sales_objection_escalating
  sales_conversation_stalling
  sales_category_transition
  sales_client_indecision
  sales_solution_understood
  conversation_dominance
  llm_insight
}

model FeedbackEvent {
  id            String           @id @default(uuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetingId     String
  participantId String
  type          FeedbackType
  severity      FeedbackSeverity
  ts            DateTime
  windowStart   DateTime
  windowEnd     DateTime
  message       String
  metadata      Json
  createdAt     DateTime         @default(now())
  expiresAt     DateTime?

  @@index([tenantId, meetingId, ts])
  @@index([expiresAt])
}
